# =============================================================================
# SELF-HOST ENVIRONMENT - Copy this file to .env and set all values
# Images are pulled from Docker Hub; no source code or build required.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DOCKER HUB IMAGES (single place: pull latest from Bellamy Book publisher)
# Use bellamy31/latest to get the latest published images; change IMAGE_TAG for a specific version.
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=bellamy31
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# DOMAIN & PUBLIC URLS (single place for all hostnames and URLs)
# Set these to YOUR domain before first run. Backend CORS, JWT issuer, and
# Traefik routes use these. Frontend and admin images have API/URLs baked in
# at build time — they must match the domain the publisher used (see README).
# IMPORTANT: FRONTEND_PUBLIC_URL and API_PUBLIC_URL are also used for robots.txt
# and sitemap (Sitemap: <FRONTEND_PUBLIC_URL>/sitemap.xml). Do NOT use localhost
# in production or Bing/Google will not find your sitemap.
# With Cloudflare Tunnel: set originRequest.httpHostHeader to this host so the
# API receives the correct Host and returns the right Sitemap URL.
# -----------------------------------------------------------------------------
# Public URLs (full base URLs; used by backend CORS, redirects, JWT issuer)
API_PUBLIC_URL=https://api.your-domain.com
FRONTEND_PUBLIC_URL=https://app.your-domain.com
ADMIN_PUBLIC_URL=https://admin.your-domain.com
# Docs: default to central Bellamy Book docs; override if you host your own
DOCS_PUBLIC_URL=https://docs.bellamybook.com

# Optional: Google Analytics 4 (GA4) – frontend SPA (bellamybook.com or your domain)
# If you want page view tracking in your frontend container, set this to your
# GA4 web data stream measurement ID (format: G-XXXXXXXXXX). Leave empty to
# disable GA4 tracking; the image will still run without it.
GA4_FRONTEND_MEASUREMENT_ID=

# Traefik hostnames (host only, no https://). Must match DNS pointing to this host.
TRAEFIK_API_HOST=api.your-domain.com
TRAEFIK_FRONTEND_HOST=app.your-domain.com
# Optional (SEO): set if you want www.your-domain.com to 301 redirect to main domain; add to CORS/Turnstile below
TRAEFIK_FRONTEND_WWW_HOST=www.your-domain.com
TRAEFIK_ADMIN_HOST=admin.your-domain.com
TRAEFIK_DOCS_HOST=docs.bellamybook.com
TRAEFIK_DASHBOARD_HOST=dashboard.your-domain.com
# Dashboard by server IP only: set to your server IP so http://YOUR_IP:8080 works
TRAEFIK_DASHBOARD_IP=192.168.1.40

# -----------------------------------------------------------------------------
# COMPOSE PROJECT NAME
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=bellamybook-prod

# -----------------------------------------------------------------------------
# MONITORING (optional profile: docker compose --profile monitoring up -d)
# No app code changes; tracks infra (Traefik, node, containers, uptime).
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
GRAFANA_ROOT_URL=http://localhost:3000
# Traefik hostnames for monitoring UIs (when behind proxy)
TRAEFIK_GRAFANA_HOST=grafana.your-domain.com
TRAEFIK_PROMETHEUS_HOST=prometheus.your-domain.com
TRAEFIK_KIBANA_HOST=kibana.your-domain.com
TRAEFIK_UPTIME_KUMA_HOST=uptime.your-domain.com

# -----------------------------------------------------------------------------
# POSTGRESQL (primary + replica) – must be "postgres", not "root" (root is for MongoDB)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_secure_postgres_password
POSTGRES_DB=FacebookDb
POSTGRES_MIGRATION_DB=MigrationDb
# Replication user (myuser) used by postgres-replica for pg_basebackup
REPLICATION_PASSWORD=CHANGE_ME_secure_replication_password

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_secure_redis_password

# -----------------------------------------------------------------------------
# MONGODB (same credentials everywhere: mongodb, mongo-init-replica, API, workers)
# Must match: docker-compose passes MONGO_ROOT_* to mongodb as MONGO_INITDB_ROOT_*
# and to mongo-init-replica / ConnectionStrings. If MongoDB was already created
# with other credentials, set these to that or remove mongo_data volume and restart.
# Avoid @ # : / in password or URL-encode them in connection strings.
# -----------------------------------------------------------------------------
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=CHANGE_ME_secure_mongo_password

# -----------------------------------------------------------------------------
# RABBITMQ
# -----------------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=CHANGE_ME_secure_rabbitmq_password
RABBITMQ_ERLANG_COOKIE=CHANGE_ME_secure_erlang_cookie
RABBITMQ_DEFAULT_VHOST=/

# -----------------------------------------------------------------------------
# KAFKA (no auth in default setup; set if using SASL)
# -----------------------------------------------------------------------------
KAFKA_BROKER_ID=1
# KAFKA_SASL_USER=
# KAFKA_SASL_PASSWORD=

# -----------------------------------------------------------------------------
# NEO4J (API + graph-worker connect via bolt://neo4j:7687; set Neo4j__Password to match password in NEO4J_AUTH below)
# -----------------------------------------------------------------------------
NEO4J_AUTH=neo4j/CHANGE_ME_secure_neo4j_password

# -----------------------------------------------------------------------------
# MINIO (match API appsettings Minio section)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_secure_minio_password

# -----------------------------------------------------------------------------
# ELASTICSEARCH (optional: enable xpack.security in compose and set)
# -----------------------------------------------------------------------------
# ELASTICSEARCH_PASSWORD=
LOG_RETENTION_DAYS=5

# -----------------------------------------------------------------------------
# EMAIL (SMTP) – set your SMTP credentials
# -----------------------------------------------------------------------------
Smtp__Server=smtp.gmail.com
Smtp__Port=587
Smtp__User=CHANGE_ME_your_smtp_email@gmail.com
Smtp__Pass=CHANGE_ME_your_smtp_app_password
Smtp__DefaultFrom=Your App Name <CHANGE_ME_your_smtp_email@gmail.com>

# -----------------------------------------------------------------------------
# BACKEND API & WORKERS (override appsettings via env)
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
# Connection strings: primary = write, replica = read (API/workers use ReadOnly for CQRS read queries)
ConnectionStrings__PrimaryConnectionString=Host=postgres-primary;Port=5432;Database=FacebookDb;Username=postgres;Password=${POSTGRES_PASSWORD};Pooling=true;MinPoolSize=5;MaxPoolSize=50
# Production CQRS: use postgres-replica for read. If replica is down, use postgres-primary temporarily.
ConnectionStrings__ReadOnlyConnectionString=Host=postgres-replica;Port=5432;Database=FacebookDb;Username=postgres;Password=${POSTGRES_PASSWORD};Pooling=true
ConnectionStrings__MigrationDbConnectionString=Host=postgres-primary;Port=5432;Database=MigrationDb;Username=postgres;Password=${POSTGRES_PASSWORD}

# Redis (required for API rate limit + stranger chat, ChatWorker/WebSocketWorker SignalR backplane)
Redis__ConnectionString=redis:6379
Redis__Password=${REDIS_PASSWORD}
Redis__Database=0

# MongoDB (use same MONGO_ROOT_USERNAME / MONGO_ROOT_PASSWORD as above)
# directConnection=true required for single-node replica set (Docker) to avoid ReplicaSetGhost / 30s timeouts
# MongoDb (capital D) = ElasticsearchSyncWorker, BlogAutoGenerationWorker
MongoDb__ConnectionString=mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@mongodb:27017/?authSource=admin&directConnection=true
MongoDb__Database=App
# MongoDB (capital B) = InteractionWorker, ScoringWorker, TrendingWorker, ChatWorker, WebSocketWorker, MediaProcessingWorker, ExpoPush, WebPush
MongoDB__ConnectionString=mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@mongodb:27017/?authSource=admin&directConnection=true
MongoDB__DatabaseName=App
# For DatabaseApplication (migrations/seeders)
ConnectionStrings__MongoDbConnectionString=mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@mongodb:27017/?authSource=admin&directConnection=true
MongoDb__DatabaseName=App

# RabbitMQ (workers + API + push notification workers)
RabbitMQ__Host=rabbitmq
RabbitMQ__Port=5672
RabbitMQ__Username=${RABBITMQ_DEFAULT_USER}
RabbitMQ__Password=${RABBITMQ_DEFAULT_PASS}
RabbitMQ__VirtualHost=/
RabbitMQ__RetryCount=3
RabbitMQ__RetryDelaySeconds=5
RabbitMQ__PrefetchCount=10
RabbitMQ__Durable=true
RabbitMQ__AutoDelete=false

# Kafka
Kafka__BootstrapServers=kafka:29092

# Neo4j (API and graph-worker; password must match the part after "neo4j/" in NEO4J_AUTH)
Neo4j__ConnectionString=bolt://neo4j:7687
Neo4j__Username=neo4j
Neo4j__Password=CHANGE_ME_secure_neo4j_password

# -----------------------------------------------------------------------------
# OBJECT STORAGE PROVIDER (MinIO or R2)
# Set Storage__Provider to "MinIO" (default) or "R2" to switch.
# -----------------------------------------------------------------------------
Storage__Provider=MinIO

# MinIO (used when Storage__Provider=MinIO) – in-stack: API connects to minio:9000, browsers use PublicUrl
# Endpoint = internal host:port for SDK (same Docker network). PublicUrl = URL for browser (images, downloads).
Minio__Endpoint=minio:9000
Minio__AccessKey=${MINIO_ROOT_USER}
Minio__SecretKey=${MINIO_ROOT_PASSWORD}
# Minio__PublicUrl = URL for frontend/admin to load media (avatars, posts). Self-host: local use http://localhost:9000; with Traefik use https://minio.your-domain.com or leave empty to use API_PUBLIC_URL host.
# Minio__PublicUrl=http://localhost:9000

# Cloudflare R2 (used when Storage__Provider=R2)
# R2__AccountId=your_cloudflare_account_id
# R2__AccessKey=your_r2_access_key_id
# R2__SecretKey=your_r2_secret_access_key
# R2__PublicUrl=https://r2.yourdomain.com

# Elasticsearch (required for Search; API depends_on elasticsearch. If ES is unreachable, set RequestTimeoutSeconds so requests fail fast.)
Elasticsearch__ConnectionString=http://elasticsearch:9200
Elasticsearch__RequestTimeoutSeconds=10
Serilog__WriteTo__1__Args__nodeUris=http://elasticsearch:9200

# JWT (generate: openssl rand -base64 64)
JwtSettings__Secret=CHANGE_ME_jwt_secret_min_32_chars
JwtSettings__Issuer=${API_PUBLIC_URL}
JwtSettings__Audience=${API_PUBLIC_URL}

# App URLs (API uses for CORS, redirects)
AppSettings__BaseUrl=${FRONTEND_PUBLIC_URL}
Frontend__BaseUrl=${FRONTEND_PUBLIC_URL}
Frontend__ApiBaseUrl=${API_PUBLIC_URL}/api
# CORS Origins (API + WebSocketWorker + ChatWorker) – app, admin, api, docs, www (if using www redirect for SEO)
Frontend__CorsOrigins__0=${FRONTEND_PUBLIC_URL}
Frontend__CorsOrigins__1=${ADMIN_PUBLIC_URL}
Frontend__CorsOrigins__2=${API_PUBLIC_URL}
Frontend__CorsOrigins__3=${DOCS_PUBLIC_URL}
Frontend__CorsOrigins__4=https://${TRAEFIK_FRONTEND_WWW_HOST}

# API host validation uses Frontend:CorsOrigins (above). Rate limit & Turnstile allowed hosts (optional override)
# Use host only, no scheme. Example: bellamybook.com
IpRateLimit__ClientWhitelist__0=${TRAEFIK_FRONTEND_HOST}
IpRateLimit__ClientWhitelist__1=${TRAEFIK_ADMIN_HOST}
IpRateLimit__ClientWhitelist__2=${TRAEFIK_API_HOST}
IpRateLimit__ClientWhitelist__3=${TRAEFIK_DOCS_HOST}
IpRateLimit__ClientWhitelist__4=${TRAEFIK_FRONTEND_WWW_HOST}
Turnstile__AllowedDomains__0=${TRAEFIK_FRONTEND_HOST}
Turnstile__AllowedDomains__1=${TRAEFIK_ADMIN_HOST}
Turnstile__AllowedDomains__2=${TRAEFIK_API_HOST}
Turnstile__AllowedDomains__3=${TRAEFIK_DOCS_HOST}
Turnstile__AllowedDomains__4=${TRAEFIK_FRONTEND_WWW_HOST}
# Turnstile (CAPTCHA) – create keys at https://dash.cloudflare.com/?to=/:account/turnstile
Turnstile__SecretKey=CHANGE_ME_turnstile_secret_key
Turnstile__SiteKey=CHANGE_ME_turnstile_site_key
Turnstile__VerificationUrl=https://challenges.cloudflare.com/turnstile/v0/siteverify
Turnstile__EnabledEndpoints__0=login
Turnstile__EnabledEndpoints__1=register
Turnstile__EnabledEndpoints__2=forgot-password
Turnstile__EnabledEndpoints__3=reset-password
Turnstile__EnabledEndpoints__4=contact

# Google OAuth – create credentials at https://console.cloud.google.com/apis/credentials
ExternalAuth__Google__ClientId=CHANGE_ME_your_google_client_id.apps.googleusercontent.com
ExternalAuth__Google__ClientSecret=CHANGE_ME_your_google_client_secret

# Web Push / VAPID – generate with: npx web-push generate-vapid-keys
WebPush__Subject=mailto:CHANGE_ME_admin@your-domain.com
WebPush__PublicKey=CHANGE_ME_vapid_public_key
WebPush__PrivateKey=CHANGE_ME_vapid_private_key

# Database app encryption – use a random base64 key (e.g. openssl rand -base64 32)
DatabaseAppAesKey=CHANGE_ME_32_char_base64_encryption_key

# License (optional)
# LicenseSystem__Mode=CONSUMER
# LicenseSystem__PrivateKey=
# LICENSE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# FRONTEND / ADMIN BUILD (Vite)
# Frontend/admin build-time env: used only when building those images from source.
# copied as .env into the image at build time (see README § Which env file).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# CHAT WORKER - SignalR backend URL (for server-side hub calls)
# -----------------------------------------------------------------------------
SignalR__ApiBaseUrl=http://api:80
SignalR__ChatHubUrl=http://api:80/hubs/chat

# -----------------------------------------------------------------------------
# LIVE CHAT (n8n AI) – disabled for self-host; users typically do not run n8n
# -----------------------------------------------------------------------------
LiveChat__Enabled=false
LiveChat__WebhookUrl=
LiveChat__Token=
LiveChat__WebhookToken=

# -----------------------------------------------------------------------------
# LIVEKIT (optional; external/cloud – not in this compose; set for real-time calls)
# Use LiveKit Cloud or a separate LiveKit/TURN server. Backend needs these for token generation.
# Frontend build needs: VITE_LIVEKIT_URL (in .env.frontend)
# -----------------------------------------------------------------------------
LiveKit__Url=wss://CHANGE_ME_your_livekit_host
LiveKit__ApiKey=CHANGE_ME_livekit_api_key
LiveKit__ApiSecret=CHANGE_ME_livekit_api_secret

# -----------------------------------------------------------------------------
# REMAINING appsettings / optional (defaults; override in .env if needed)
# -----------------------------------------------------------------------------
AllowedHosts=*
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
# Do NOT set AppSettings__BaseUrl to localhost in production; it is set from FRONTEND_PUBLIC_URL above (and in docker-compose) for robots.txt/sitemap.
# AppSettings__BaseUrl=http://localhost:5173
LicenseSystem__Mode=MAIN
LicenseSystem__PrivateKey=CHANGE_ME_license_private_key_if_using_consumer_mode
LicenseSystem__ValidationEndpoint=
# JWT: do NOT duplicate here – use the block above (JwtSettings__Secret, __Issuer, __Audience with ${API_PUBLIC_URL}). Duplicate values here break login after deploy.
# Access token expiry (minutes). Backend reads JwtSettings__ExpirationMinutes. 15 = good security; use 30 for fewer refresh-token API calls.
JwtSettings__ExpirationMinutes=15
Elasticsearch__IndexPrefix=socialnetwork
Elasticsearch__AutoInitialize=false
Elasticsearch__UseCachedSearch=true
Neo4j__Database=neo4j
Neo4j__MaxConnectionPoolSize=50
Neo4j__ConnectionTimeout=30000
Neo4j__MaxTransactionRetryTime=30000
Quartz__SampleJob=0 * * ? * * *
Quartz__BackgroundJobSample=*/5 * * * * ?
Quartz__RefreshTokenCleanupJob=0 0 * * * ?
Quartz__UserSyncJob=0 * * * * ?
Quartz__ElasticsearchSyncJob=0 */15 * * * ?
Quartz__TempFileCleanupJob=0 0 */6 * * ?
Quartz__StoryCleanupJob=0 0 * * * ?
Quartz__BirthdayNotificationJob=0 0 0 * * ?
Quartz__EmailCampaignJob=0 * * ? * *
Quartz__PollExpirationJob=0 */15 * * * ?
Quartz__LicenseValidationJob=0 0 0 ? * MON
Quartz__ScheduledBackupJob=0 0 2 * * ?
Backup__Enabled=false
Backup__Schedule=0 0 2 * * ?
Backup__RetentionDays=30
Backup__Storage__Type=MinIO
# Backup uses same storage as media (Minio/R2); only bucket name is needed
Backup__Storage__MinIO__Bucket=backups
Backup__Databases__PostgreSQL=true
Backup__Databases__MongoDB=true
Backup__Databases__Neo4j=true
Backup__Databases__Elasticsearch=true
Backup__Databases__Redis=false
RefreshTokenSettings__TtlDays=14
Frontend__AppName=Bellamy Book
Lockout__MaxFailedAccessAttempts=5
Lockout__DefaultLockoutMinutes=15
Redis__UseSentinel=false
Redis__KeyPrefix=local:
# =============================================================================
# RATE LIMITING - Per client IP; ensure proxy forwards X-Forwarded-For (real client IP).
# =============================================================================
# RATE LIMITING - Production Configuration
# Optimized for 1 heavy user while preventing spam/hacks
# =============================================================================
IpRateLimiting__EnableEndpointRateLimiting=true
# Enable StackBlockedRequests to queue excessive requests instead of immediate rejection
# This provides better UX for legitimate heavy users while still protecting against abuse
IpRateLimiting__StackBlockedRequests=true
IpRateLimiting__RealIpHeader=X-Real-IP
IpRateLimiting__ClientIdHeader=X-ClientId
IpRateLimiting__HttpStatusCode=429
IpRateLimiting__QuotaExceededMessage=Rate limit exceeded. Please try again later.
IpRateLimiting__IpWhitelist__0=127.0.0.1
IpRateLimiting__IpWhitelist__1=::1
# Load test: bỏ comment dòng dưới, thay YOUR_LOAD_TEST_IP bằng IP máy chạy k6 (vd. IP laptop/VPS) để không bị 429 khi chạy load test. Sau khi test xong nên comment lại.
# IpRateLimiting__IpWhitelist__2=YOUR_LOAD_TEST_IP
IpRateLimiting__EndpointWhitelist__0=get:/health
IpRateLimiting__EndpointWhitelist__1=*:/swagger/*
IpRateLimiting__EndpointWhitelist__2=post:/api/authentication/refresh-token

# IP Rate Limiting - General Rules (increased for heavy user, still prevents abuse)
# Hourly limit: 3000 requests/hour (supports heavy user activity)
IpRateLimiting__GeneralRules__0__Endpoint=*
IpRateLimiting__GeneralRules__0__Period=1h
IpRateLimiting__GeneralRules__0__Limit=3000
# 15-minute burst: 800 requests (allows active browsing sessions)
IpRateLimiting__GeneralRules__1__Endpoint=*
IpRateLimiting__GeneralRules__1__Period=15m
IpRateLimiting__GeneralRules__1__Limit=800
# 5-minute burst: 300 requests (handles rapid interactions)
IpRateLimiting__GeneralRules__2__Endpoint=*
IpRateLimiting__GeneralRules__2__Period=5m
IpRateLimiting__GeneralRules__2__Limit=300
# 1-minute burst: 100 requests (prevents rapid-fire abuse)
IpRateLimiting__GeneralRules__3__Endpoint=*
IpRateLimiting__GeneralRules__3__Period=1m
IpRateLimiting__GeneralRules__3__Limit=100

# IP Rate Limiting - Auth Endpoints (strict to prevent brute force)
# Login attempts: 30/hour, 10/15min (prevents credential stuffing while allowing legitimate retries)
IpRateLimiting__GeneralRules__4__Endpoint=post:/api/authentication/login
IpRateLimiting__GeneralRules__4__Period=1h
IpRateLimiting__GeneralRules__4__Limit=30
IpRateLimiting__GeneralRules__5__Endpoint=post:/api/authentication/login
IpRateLimiting__GeneralRules__5__Period=15m
IpRateLimiting__GeneralRules__5__Limit=10
# Registration: 10/hour, 3/15min (prevents spam accounts)
IpRateLimiting__GeneralRules__6__Endpoint=post:/api/authentication/register
IpRateLimiting__GeneralRules__6__Period=1h
IpRateLimiting__GeneralRules__6__Limit=10
IpRateLimiting__GeneralRules__7__Endpoint=post:/api/authentication/register
IpRateLimiting__GeneralRules__7__Period=15m
IpRateLimiting__GeneralRules__7__Limit=3
# Password reset: 10/hour, 3/15min (prevents abuse)
IpRateLimiting__GeneralRules__8__Endpoint=post:/api/authentication/forgot-password
IpRateLimiting__GeneralRules__8__Period=1h
IpRateLimiting__GeneralRules__8__Limit=10
IpRateLimiting__GeneralRules__9__Endpoint=post:/api/authentication/reset-password
IpRateLimiting__GeneralRules__9__Period=1h
IpRateLimiting__GeneralRules__9__Limit=10

# IP Rate Limiting - Content Creation (prevents spam)
# Blog posts: 50/hour, 15/15min (allows active content creators)
IpRateLimiting__GeneralRules__10__Endpoint=post:/api/blog
IpRateLimiting__GeneralRules__10__Period=1h
IpRateLimiting__GeneralRules__10__Limit=50
IpRateLimiting__GeneralRules__11__Endpoint=post:/api/blog
IpRateLimiting__GeneralRules__11__Period=15m
IpRateLimiting__GeneralRules__11__Limit=15
# Download endpoints: 50/hour, 10/15min (prevents scraping)
IpRateLimiting__GeneralRules__12__Endpoint=get:/api/blogs/download/*
IpRateLimiting__GeneralRules__12__Period=1h
IpRateLimiting__GeneralRules__12__Limit=50
IpRateLimiting__GeneralRules__13__Endpoint=get:/api/blogs/download/*
IpRateLimiting__GeneralRules__13__Period=15m
IpRateLimiting__GeneralRules__13__Limit=10

# Client Rate Limiting (per client ID - supports heavy user with multiple sessions)
ClientRateLimiting__EnableEndpointRateLimiting=true
# Enable StackBlockedRequests for client rate limiting too
ClientRateLimiting__StackBlockedRequests=true
ClientRateLimiting__ClientIdHeader=X-ClientId
ClientRateLimiting__HttpStatusCode=429
ClientRateLimiting__QuotaExceededMessage=Client rate limit exceeded. Please try again later.
ClientRateLimiting__ClientWhitelist__0=admin-client
ClientRateLimiting__ClientWhitelist__1=trusted-client
ClientRateLimiting__EndpointWhitelist__0=post:/api/authentication/refresh-token

# Client Rate Limiting - General Rules
# Hourly limit: 8000 requests/hour (supports heavy user with multiple devices/sessions)
ClientRateLimiting__GeneralRules__0__Endpoint=*
ClientRateLimiting__GeneralRules__0__Period=1h
ClientRateLimiting__GeneralRules__0__Limit=8000
# 15-minute burst: 2000 requests
ClientRateLimiting__GeneralRules__1__Endpoint=*
ClientRateLimiting__GeneralRules__1__Period=15m
ClientRateLimiting__GeneralRules__1__Limit=2000
# 1-minute burst: 200 requests
ClientRateLimiting__GeneralRules__2__Endpoint=*
ClientRateLimiting__GeneralRules__2__Period=1m
ClientRateLimiting__GeneralRules__2__Limit=200

# Client Rate Limiting - Auth Endpoints (strict)
# Login: 20/hour, 8/15min
ClientRateLimiting__GeneralRules__3__Endpoint=post:/api/auth/*
ClientRateLimiting__GeneralRules__3__Period=1h
ClientRateLimiting__GeneralRules__3__Limit=20
ClientRateLimiting__GeneralRules__4__Endpoint=post:/api/auth/*
ClientRateLimiting__GeneralRules__4__Period=15m
ClientRateLimiting__GeneralRules__4__Limit=8
# Blog posts: 60/hour, 20/15min
ClientRateLimiting__GeneralRules__5__Endpoint=post:/api/blog/*
ClientRateLimiting__GeneralRules__5__Period=1h
ClientRateLimiting__GeneralRules__5__Limit=60
ClientRateLimiting__GeneralRules__6__Endpoint=post:/api/blog/*
ClientRateLimiting__GeneralRules__6__Period=15m
ClientRateLimiting__GeneralRules__6__Limit=20
Turnstile__AllowedDomains__0=localhost
Turnstile__AllowedDomains__1=127.0.0.1
Turnstile__AllowedDomains__2=your-domain.com
Turnstile__AllowedDomains__3=www.your-domain.com
Turnstile__AllowedDomains__4=docs.bellamybook.com
Turnstile__AllowedDomains__5=admin.your-domain.com
Turnstile__AllowedDomains__6=api.your-domain.com
LocationService__ApiBaseUrl=http://ip-api.com/json
LocationService__CacheHours=24
# API only. Do NOT use api-group for workers: each worker must have its own GroupId (docker-compose sets them per service).
Kafka__GroupId=api-group
Kafka__ClientId=api-client
Kafka__EnableAutoCommit=false
Kafka__AutoCommitIntervalMs=5000
Kafka__AutoOffsetReset=earliest
Kafka__SessionTimeoutMs=45000
Kafka__MaxPollIntervalMs=300000
Kafka__FetchMinBytes=1
Kafka__FetchMaxWaitMs=500
Kafka__MaxPartitionFetchBytes=1048576
Kafka__EnableAutoOffsetStore=false
Kafka__StatisticsIntervalMs=60000
Kafka__MessageTimeoutMs=30000
Kafka__RequestTimeoutMs=30000
Kafka__Acks=all
Kafka__Retries=3
Kafka__RetryBackoffMs=100
Kafka__CompressionType=snappy
Kafka__BatchSize=16384
Kafka__LingerMs=10
Kafka__BufferMemory=33554432
KafkaTopics__UserInteractedTopic=user_interacted
KafkaTopics__ContentCreatedTopic=content_created
KafkaTopics__ContentUpdatedTopic=content_updated
KafkaTopics__ContentDeletedTopic=content_deleted
KafkaTopics__HashtagEventsTopic=hashtag_events
KafkaTopics__NumPartitions=3
KafkaTopics__ReplicationFactor=1
