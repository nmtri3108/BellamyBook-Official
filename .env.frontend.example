# =============================================================================
# FRONTEND BUILD – domain/config for the frontend image (publisher only)
# =============================================================================
# For image builders only: copy this to your build environment when building
# the frontend Docker image from source. Values are BAKED INTO the image.
# Self-hosters using pre-built images do not need this file.
# =============================================================================

# REQUIRED – set to your public URLs (same domain as .env API_PUBLIC_URL etc.)
VITE_API_BASE_URL=https://api.your-domain.com/api
VITE_APP_ENV=production
VITE_DOCS_URL=https://docs.bellamybook.com

# APP
VITE_APP_NAME=Bellamy Book
VITE_APP_VERSION=1.0.0
VITE_APP_TITLE=Bellamy Book - App
VITE_APP_DESCRIPTION=A modern social networking application

# API
VITE_API_TIMEOUT=15000
VITE_API_RETRIES=1
VITE_API_RETRY_DELAY=500

# AUTH
VITE_AUTH_TOKEN_KEY=authKey
VITE_AUTH_REFRESH_THRESHOLD=120000
VITE_AUTH_LOGIN_PATH=/auth/sign-in
VITE_AUTH_LOGOUT_PATH=/auth/sign-in

# FEATURE FLAGS
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUGGING=false
VITE_ENABLE_SERVICE_WORKER=false
VITE_FEATURE_FLAGS={"newDesign":true,"betaFeatures":true,"advancedSearch":true,"devTools":false}

# CACHE / LOGGING / UI
VITE_CACHE_DURATION=60000
VITE_CACHE_MAX_SIZE=20
VITE_CACHE_VERSION=1.0
VITE_LOG_LEVEL=info
VITE_LOG_CONSOLE=true
VITE_LOG_REMOTE=false
VITE_SENTRY_DSN=
VITE_UI_THEME=dark
VITE_UI_LANGUAGE=en
VITE_UI_ITEMS_PER_PAGE=10
VITE_UI_DEBOUNCE_DELAY=100

# SOCIAL
VITE_SOCIAL_MAX_FILE_SIZE=5242880
VITE_SOCIAL_ALLOWED_FILE_TYPES=image/*,video/*
VITE_SOCIAL_MAX_POST_LENGTH=1000
VITE_SOCIAL_ENABLE_LIVE_CHAT=true
VITE_ENABLE_ADS=false

# PRODUCTION
VITE_USE_MOCK_API=false
VITE_ENABLE_HOT_RELOAD=false
VITE_SHOW_PERFORMANCE_METRICS=false

# Domain – API and SignalR (same as API_PUBLIC_URL host)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_SIGNALR_BASE_URL=https://api.your-domain.com
VITE_CHAT_HUB_URL=https://api.your-domain.com
VITE_FORCE_LOCAL=false

# Turnstile (CAPTCHA) – set your keys or leave if using shared
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
VITE_TURNSTILE_THEME=dark
VITE_TURNSTILE_SIZE=normal
VITE_TURNSTILE_ENABLED_ENDPOINTS=login,register,forgot-password,reset-password,contact

# LiveKit – your LiveKit Cloud or self-hosted URL
VITE_LIVEKIT_URL=wss://your-livekit.example.com

# Web Push – VAPID public key (must match backend WebPush:PublicKey)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Object storage public URL (MinIO or R2 — change to your R2 URL when using R2)
VITE_STORAGE_PUBLIC_URL=https://minio.your-domain.com

# Admin URL (links from frontend to admin)
VITE_ADMIN_URL=https://admin.your-domain.com
