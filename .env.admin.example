# =============================================================================
# ADMIN BUILD – domain/config for the admin image (publisher only)
# =============================================================================
# For image builders only: copy this to your build environment when building
# the admin Docker image from source. Self-hosters using pre-built images do not need this file.
# =============================================================================

VITE_NODE_ENV=production

# REQUIRED – set to your public URLs (same domain as .env and .env.frontend.example)
VITE_API_URL=https://api.your-domain.com/api
VITE_USER_FRONTEND_URL=https://app.your-domain.com
VITE_ADMIN_URL=https://admin.your-domain.com
VITE_API_TIMEOUT=10000

VITE_APP_TITLE=Bellamy Book Admin
VITE_APP_VERSION=1.0.0

VITE_ENABLE_DEBUG=false
VITE_ENABLE_LOGGING=true
VITE_DEFAULT_THEME=dark
VITE_SIDEBAR_COLLAPSED=false
VITE_ENABLE_HOT_RELOAD=false
VITE_ENABLE_SOURCE_MAPS=false
VITE_FORCE_LOCAL=false

# Turnstile (CAPTCHA)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
VITE_TURNSTILE_THEME=light
VITE_TURNSTILE_SIZE=normal
VITE_TURNSTILE_ENABLED_ENDPOINTS=login,register,forgot-password,reset-password,contact

# Web Push – VAPID public key (must match backend WebPush:PublicKey)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Object storage public URL (MinIO or R2 depending on backend Storage__Provider)
VITE_STORAGE_PUBLIC_URL=https://minio.your-domain.com
